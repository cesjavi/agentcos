rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /projects/{projectId} {
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /agents/{agentId} {
      allow read, create, update, delete: if isSignedIn();
    }

    match /prompts/{promptId} {
      allow read, write: if isSignedIn();
    }

    match /promptVersions/{versionId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /executions/{executionId} {
      allow read, write: if isSignedIn();
    }

    match /executionLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /feedback/{feedbackId} {
      allow read, write: if isSignedIn();
    }

    match /memories/{memoryId} {
      allow read, write: if isSignedIn();
    }

    match /userSettings/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
